{
  "contracts": {
    "system/query/browsers": {
      "version": "v1",
      "effect": "query",
      "reversible": false,
      "inp": {},
      "out": {
        "connector": "const:browser-control",
        "browsers": "list",
        "default": "?str",
        "display": "bool"
      },
      "errors": [],
      "examples": [
        {
          "payload": {},
          "result": {
            "ok": true,
            "connector": "browser-control",
            "browsers": [],
            "default": null,
            "display": false
          }
        }
      ]
    },
    "page/command/open": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "url": "str", "target": "?str", "timeout": "?num" },
      "out": {
        "connector": "const:browser-control",
        "target": "str",
        "url": "str",
        "executed": "?bool",
        "backend": "?str"
      },
      "errors": ["unreachable", "degraded-backend"],
      "examples": [
        {
          "payload": { "url": "https://example.com" },
          "result": {
            "ok": true,
            "connector": "browser-control",
            "target": "desktop",
            "url": "https://example.com",
            "executed": false,
            "backend": "none",
            "reason": "Set BROWSER_CONTROL_ENDPOINT or URI_SERVICE_MAP to forward to a noVNC/urirun node. Set BROWSER_CONTROL_ALLOW_LOCAL=1 to open the local host browser."
          }
        }
      ]
    },
    "page/command/screenshot": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "url": "?str", "target": "?str", "output": "?str", "timeout": "?num" },
      "out": {
        "connector": "const:browser-control",
        "target": "str",
        "url": "?str",
        "output": "?str"
      },
      "errors": ["unreachable", "precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "url": "https://example.com" },
          "result": {
            "ok": true,
            "connector": "browser-control",
            "target": "desktop",
            "url": "https://example.com",
            "output": "browser-screenshot.png",
            "executed": false,
            "backend": "none",
            "reason": "Set BROWSER_CONTROL_ENDPOINT or URI_SERVICE_MAP to forward screenshots to a browser/noVNC node."
          }
        }
      ]
    },
    "page/query/dom": {
      "version": "v1",
      "effect": "query",
      "reversible": false,
      "inp": { "url": "?str", "max": "?int" },
      "out": {
        "connector": "const:browser-control",
        "target": "const:chrome",
        "url": "?str"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "url": "https://example.com" },
          "result": {
            "ok": true,
            "connector": "browser-control",
            "target": "chrome",
            "executed": false,
            "backend": "none",
            "reason": "no Chrome/Chromium binary found; install one to run headless routes",
            "url": "https://example.com"
          }
        }
      ]
    },
    "page/query/text": {
      "version": "v1",
      "effect": "query",
      "reversible": false,
      "inp": { "url": "?str", "max": "?int" },
      "out": {
        "connector": "const:browser-control",
        "target": "const:chrome",
        "url": "?str"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "url": "https://example.com" },
          "result": {
            "ok": true,
            "connector": "browser-control",
            "target": "chrome",
            "executed": false,
            "backend": "none",
            "reason": "no Chrome/Chromium binary found; install one to run headless routes",
            "url": "https://example.com"
          }
        }
      ]
    },
    "session/command/launch": {
      "version": "v1",
      "effect": "command",
      "reversible": true,
      "inverseRoute": "session/command/close",
      "inp": { "browser": "?str", "url": "?str", "headless": "?bool" },
      "out": {
        "connector": "const:browser-control",
        "target": "enum:kvm|cdp"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "browser": "firefox" },
          "result": {
            "ok": false,
            "connector": "browser-control",
            "target": "kvm",
            "browser": "firefox",
            "error": "no binary for browser 'firefox'",
            "tried": ["firefox", "firefox-esr"]
          }
        }
      ]
    },
    "input/command/type": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "text": "str", "enter": "?bool" },
      "out": {
        "connector": "const:browser-control",
        "target": "const:kvm"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "text": "hello" },
          "result": {
            "ok": false,
            "connector": "browser-control",
            "target": "kvm",
            "error": "no input tool (install ydotool for Wayland, or xdotool for X11)"
          }
        }
      ]
    },
    "input/command/hotkey": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "keys": ["str"] },
