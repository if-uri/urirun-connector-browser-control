        "mode": "const:read-only",
        "domain": "str",
        "url": "str",
        "found": "bool",
        "selected": "?obj",
        "candidates": "list",
        "safety": "str"
      },
      "errors": [],
      "examples": [
        {
          "payload": {},
          "result": {
            "ok": true,
            "connector": "browser-control",
            "target": "cdp",
            "mode": "read-only",
            "domain": "linkedin.com",
            "url": "https://www.linkedin.com/",
