          }
        }
      ]
    },
    "page/command/navigate": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "url": "str", "enter": "?bool", "wait_ready": "?bool", "timeout": "?num" },
      "out": {
        "connector": "const:browser-control",
        "target": "enum:kvm|cdp",
        "url": "?str"
