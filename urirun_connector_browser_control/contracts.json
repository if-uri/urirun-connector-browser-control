            "ok": false,
            "connector": "browser-control",
            "target": "kvm",
            "capture": { "ok": false, "error": "no working screenshot tool (grim/import/scrot/maim/gnome-screenshot)" },
            "ocr": { "ok": false, "error": "no screenshot path for OCR" },
            "contains": "",
            "matched": false
          }
        }
      ]
    },
