          "payload": { "url": "https://example.com" },
          "result": {
            "ok": false,
            "connector": "browser-control",
            "target": "kvm",
            "url": "https://example.com",
            "steps": {
              "focus": { "ok": false, "connector": "browser-control", "target": "kvm", "error": "no input tool (install ydotool/xdotool)" },
              "type": { "ok": false, "connector": "browser-control", "target": "kvm", "error": "no input tool (install ydotool for Wayland, or xdotool for X11)" }
            }
          }
        }
      ]
    },
    "input/command/click": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "x": "int", "y": "int", "button": "?str" },
      "out": {
        "connector": "const:browser-control",
        "target": "const:kvm"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
