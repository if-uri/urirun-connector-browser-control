        {
          "payload": { "x": 100, "y": 200 },
          "result": {
            "ok": false,
            "connector": "browser-control",
            "target": "kvm",
            "error": "coordinate click needs xdotool (X11); on Wayland use page/command/click-text"
          }
        }
      ]
    },
    "page/command/click-text": {
      "version": "v1",
      "effect": "command",
      "reversible": false,
      "inp": { "text": "str" },
      "out": {
        "connector": "const:browser-control",
        "target": "const:kvm"
      },
      "errors": ["precondition-unmet", "degraded-backend"],
      "examples": [
        {
          "payload": { "text": "Login" },
          "result": {
            "ok": false,
            "connector": "browser-control",
            "target": "kvm",
            "error": "click-text needs tellmesh urikvm (OCR) or tesseract on the node"
          }
        }
      ]
    },
    "screen/query/capture": {
      "version": "v1",
      "effect": "query",
